MELP_ENV=dev
MELP_LOG_LEVEL=INFO

# Postgres
MELP_DB_URL=postgresql+psycopg://melp:melp@localhost:5432/melp

# Redis
MELP_REDIS_URL=redis://localhost:6379/0

# Object store (MinIO in dev, S3 in prod)
MELP_S3_ENDPOINT=http://localhost:9000
MELP_S3_REGION=us-east-1
MELP_S3_ACCESS_KEY=melp
MELP_S3_SECRET_KEY=melpmelpmelp
MELP_S3_BUCKET_ARTIFACTS=melp-artifacts
MELP_S3_BUCKET_DATASETS=melp-datasets
MELP_S3_BUCKET_RESULTS=melp-results

# Temporal
MELP_TEMPORAL_HOST=localhost:7233
MELP_TEMPORAL_NAMESPACE=melp

# Auth (dev OIDC stub)
MELP_AUTH_MODE=dev
MELP_AUTH_DEV_USER=dev@example.com
MELP_AUTH_OIDC_ISSUER=
MELP_AUTH_OIDC_CLIENT_ID=
MELP_AUTH_JWT_SECRET=insecure-dev-secret-change-me

# Judge / LLM gateway (Phase 2)
MELP_LLM_GATEWAY_URL=http://localhost:9100
MELP_LLM_GATEWAY_TOKEN=dev
MELP_JUDGE_TOKEN_BUDGET_PER_MIN=100000

# Service ports
MELP_PORT_GATEWAY=8000
MELP_PORT_AUTHZ=8001
MELP_PORT_RUN=8010
MELP_PORT_DATASET=8011
MELP_PORT_MODEL=8012
MELP_PORT_METRIC=8013
MELP_PORT_JUDGE_CONFIG=8014
MELP_PORT_PROJECT=8015
MELP_PORT_AUDIT=8016
MELP_PORT_AGGREGATOR=8017
MELP_PORT_JUDGE_ORCH=8018
